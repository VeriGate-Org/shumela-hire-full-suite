# ShumelaHire Frontend Environment Variables
# Copy this to .env.local and fill in the values

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# App URL (for callbacks, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AWS Cognito (populated after CDK deployment)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=           # Cognito Hosted UI domain (e.g., shumelahire.auth.af-south-1.amazoncognito.com)
NEXT_PUBLIC_REGION=af-south-1

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ShumelaHire Hybrid Deployment Environment Variables
# Copy this file to .env.hybrid and fill in the values

# Database (SQL Server)
DATABASE_PASS=YourStrongPassword123!
DATABASE_USER=sa
DATABASE_URL=jdbc:sqlserver://localhost:1433;databaseName=shumelahire;encrypt=true;trustServerCertificate=true

# Security
JWT_SECRET=your-256-bit-secret-key-here
ENCRYPTION_KEY=your-base64-encoded-aes-256-key

# File Storage (local filesystem)
UPLOAD_DIR=/opt/shumelahire/uploads

# Spring Profile
SPRING_PROFILES_ACTIVE=hybrid
